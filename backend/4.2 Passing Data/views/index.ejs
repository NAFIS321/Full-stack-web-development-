<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Name Letters</title>
</head>

<body>
 

  <% if (locals.numberOfLetters){ %>
   <h1> This is your number<%= numberOfLetters %> of letter !!!!</h1>

  <% }else { %> 
    
